.PHONY: dev build preview test lint clean

# Development (with LAN access for mobile testing)
dev:
	npm run dev

# Build for production
build:
	npm run build

# Preview production build
preview:
	npm run preview

# Run unit tests
test:
	npm run test

# Run E2E tests
test-e2e:
	npm run test:e2e

# Lint
lint:
	npm run lint

# Install dependencies
install:
	npm install

# Clean build artifacts
clean:
	rm -rf dist node_modules/.vite
